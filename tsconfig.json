{
    "compilerOptions": {
        "noEmit": true,
        "target": "ESNext",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitAny": true,
        "noFallthroughCasesInSwitch": true,
        "strictNullChecks": true,
        "moduleResolution": "Bundler",
        "module": "ESNext",
        "types": [
            "bun",
            "node",
            "prismjs",
        ],
        "lib": [
            "esnext",
            "dom"
        ],
    },
    "include": [
        "./**/*.ts"
    ]
}